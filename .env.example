# Used for Edge Functions (AI Counselor, Paywall) and optional Supabase Auth.
# Copy to `.env` and fill with your own values. Never commit real keys.
# Use the full project URL, e.g. https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PROJECT_ID=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_ANON_KEY
# Auth: enable Email provider in Supabase Dashboard → Authentication → Providers.
# For local dev, turn off "Confirm email" or you'll need to click the link before first login.
#
# Optional: POST privacy-light JSON events (see docs/PRODUCT_ANALYTICS.md). No PII is sent from the app.
# Supabase Edge (deployed make-server): append /analytics/event to your functions base URL.
# Authorization uses VITE_SUPABASE_ANON_KEY automatically when set.
# VITE_ANALYTICS_ENDPOINT=https://YOUR_PROJECT_REF.supabase.co/functions/v1/make-server-76b0ba9a/analytics/event
#
# Optional: client error reporting (production only). No Session Replay. See docs/ERROR_MONITORING.md
# VITE_SENTRY_DSN=https://PUBLIC_KEY@o000000.ingest.sentry.io/0000000
# VITE_APP_ENV=staging
#
# Internal admin docs (Blueprint): comma-separated emails that may open / blueprint in the app.
# Production builds: set this to your team addresses. Leave unset to hide docs from all parents.
# VITE_ADMIN_EMAILS=you@yourdomain.com,admin@yourdomain.com
#
# Local dev only: allow any session to open Blueprint without email allowlist (never ship "true" to prod CI).
# VITE_BLUEPRINT_DEV_OPEN=true
#
# Optional: comma/space-separated feature flags (build-time). Example: payments_remote_kill
# stops Razorpay checkout without a new app build (set in hosting env).
# VITE_FEATURE_FLAGS=payments_remote_kill
#
# Full credential checklist (Supabase, Razorpay, Edge secrets, remote flags): docs/SETUP_CREDENTIALS.md
