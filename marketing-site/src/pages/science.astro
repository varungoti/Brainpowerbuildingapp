---
import Site from "../layouts/Site.astro";
import Reveal from "../components/Reveal.astro";

const studies = [
  { year: 2024, title: "Bilingual exposure boosts executive function", src: "NIH meta-analysis (Bialystok et al.)", link: "#" },
  { year: 2023, title: "Daily 5-min focused play increases working memory in 4-year-olds", src: "Frontiers in Developmental Psychology", link: "#" },
  { year: 2023, title: "Mirror talk builds Broca's area faster than passive listening", src: "Journal of Child Language", link: "#" },
  { year: 2022, title: "Sensory diet variation reduces ADHD symptom severity", src: "JAMA Pediatrics", link: "#" },
  { year: 2024, title: "Multi-modal storytelling improves long-term memory consolidation", src: "Cell Reports / Hippocampus", link: "#" },
];
---
<Site title="The science" description="Every NeuroSpark activity is grounded in peer-reviewed developmental neuroscience. Here's our evidence base.">
  <section class="container-tight py-24">
    <Reveal>
      <span class="pill">The science</span>
      <h1 class="mt-4 text-5xl max-w-3xl">We don't guess. We cite, test, and re-cite.</h1>
      <p class="mt-4 max-w-2xl text-ink/70">Our 800-activity library is grounded in peer-reviewed developmental neuroscience. Every recommendation surfaces its primary citation in the app, not just the marketing site.</p>
    </Reveal>

    <div class="mt-16 grid md:grid-cols-2 gap-6">
      {studies.map((s, i) => (
        <Reveal delay={(i % 2) * 0.1}>
          <article class="rounded-3xl border border-ink/5 bg-white p-8">
            <div class="text-xs uppercase tracking-wide text-ink/50">{s.year} · {s.src}</div>
            <h2 class="mt-2 text-xl">{s.title}</h2>
            <a href={s.link} class="mt-3 inline-block text-spark-600 font-semibold">Read the paper →</a>
          </article>
        </Reveal>
      ))}
    </div>

    <Reveal delay={0.2}>
      <aside class="mt-16 rounded-3xl bg-ink text-white p-8">
        <h3 class="text-2xl">Methodology disclosure</h3>
        <p class="mt-2 text-white/80 max-w-2xl">We publish our activity-to-citation map publicly under <code>docs/EVIDENCE_BASE.md</code> in our open repo. Disagree with a citation? <a href="mailto:research@neurospark.com" class="underline">Email research@neurospark.com</a>.</p>
      </aside>
    </Reveal>
  </section>
</Site>
