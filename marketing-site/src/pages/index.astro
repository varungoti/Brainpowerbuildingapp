---
import Site from "../layouts/Site.astro";
import Reveal from "../components/Reveal.astro";
import HeroOrb from "../components/HeroOrb.astro";
import BrainMap from "../components/BrainMap.astro";
---
<Site title="Build the brain your kid will need in 2035" description="Playful brain-building activities for ages 0–7. Privacy-first. AI-age ready.">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg pointer-events-none opacity-60" aria-hidden="true"></div>
    <div class="container-tight grid md:grid-cols-2 gap-16 py-24 md:py-32 items-center relative">
      <div>
        <span class="pill">For ages 0–7</span>
        <h1 class="mt-5 text-5xl md:text-6xl leading-[1.05]">
          Build the brain<br />your kid will need<br /><span class="text-spark-500">in 2035.</span>
        </h1>
        <p class="mt-6 max-w-md text-lg text-ink/70">
          NeuroSpark turns five spare minutes into focused, evidence-backed brain-building. 15 brain regions, 16 AI-age competencies, zero ads, no creepy data.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/download" class="btn-primary">Get NeuroSpark — free</a>
          <a href="/science" class="btn-ghost">See the research</a>
        </div>
        <div class="mt-6 flex items-center gap-4 text-xs text-ink/50">
          <span>★★★★★ 4.9 in beta</span><span>·</span><span>3,500+ families</span><span>·</span><span>HIPAA-grade privacy</span>
        </div>
      </div>
      <Reveal y={60}>
        <HeroOrb />
      </Reveal>
    </div>
  </section>

  <section class="py-24 bg-white/70">
    <div class="container-tight">
      <Reveal>
        <span class="pill">15-region brain map</span>
        <h2 class="mt-4 text-4xl">Every activity, mapped to the region it grows.</h2>
        <p class="mt-3 max-w-2xl text-ink/70">Hover any region to see the activity types we use to develop it. We track coverage so no part of your child's brain is accidentally over- or under-developed.</p>
      </Reveal>
      <div class="mt-12">
        <BrainMap />
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="container-tight grid md:grid-cols-3 gap-8">
      <Reveal delay={0}>
        <h3 class="text-2xl">5 minutes a day</h3>
        <p class="mt-2 text-ink/70">Micro-activities that fit between diaper changes and bedtime stories — no commitment, no guilt.</p>
      </Reveal>
      <Reveal delay={0.1}>
        <h3 class="text-2xl">Adapts to your child</h3>
        <p class="mt-2 text-ink/70">On-device ML adjusts difficulty per rolling engagement, not vague "age groups". Your data never leaves your device.</p>
      </Reveal>
      <Reveal delay={0.2}>
        <h3 class="text-2xl">AI-age ready</h3>
        <p class="mt-2 text-ink/70">Boosts the 16 competencies that matter most as kids grow up alongside AI: focus, originality, ethical reasoning, embodied skill.</p>
      </Reveal>
    </div>
  </section>

  <section class="py-24 bg-deep-500 text-white relative overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-spark-500 blur-3xl opacity-40 animate-float-slow" aria-hidden="true"></div>
    <div class="container-tight relative">
      <Reveal>
        <h2 class="text-4xl max-w-2xl">"My 4-year-old asked for the brain game instead of the iPad."</h2>
        <p class="mt-3 text-white/80">— Aishwarya, mum of two, Pune</p>
      </Reveal>
      <div class="mt-10 flex gap-3">
        <a href="/download" class="btn-primary">Try it tonight</a>
        <a href="/blog" class="btn-ghost text-ink">Read the blog</a>
      </div>
    </div>
  </section>
</Site>
