---
import Site from "../layouts/Site.astro";
import Reveal from "../components/Reveal.astro";
---
<Site title="The AI-Age Standard" description="An open, citation-backed competency framework for the AI generation. Free for any developmental product to adopt.">
  <section class="container-tight py-24">
    <Reveal>
      <span class="pill">Open standard</span>
      <h1 class="mt-4 text-5xl max-w-3xl">The AI-Age Standard. <span class="text-spark-500">Open. Auditable.</span> Yours to adopt.</h1>
      <p class="mt-4 max-w-2xl text-ink/70">
        12 peer-reviewed-cited child competencies that won't be commoditised by LLMs, packaged as a versioned JSON spec, a TypeScript reference scorer, and a one-line verifier badge. Free for any developmental product, school, or research group to adopt.
      </p>
    </Reveal>

    <div class="mt-10 grid md:grid-cols-3 gap-4">
      <Reveal>
        <a href="https://api.neurospark.com/standard/spec.json" class="block rounded-2xl border border-ink/5 bg-white p-6 hover:border-spark-500/40 transition">
          <div class="text-xs text-deep-500 font-bold">VERSIONED SPEC</div>
          <div class="mt-1 text-lg font-semibold">spec.json</div>
          <p class="mt-2 text-sm text-ink/60">SemVer JSON, citation-backed, immutable per version. Diff-friendly for adopters.</p>
        </a>
      </Reveal>
      <Reveal delay={0.05}>
        <a href="https://www.npmjs.com/package/@neurospark/ai-age" class="block rounded-2xl border border-ink/5 bg-white p-6 hover:border-spark-500/40 transition">
          <div class="text-xs text-deep-500 font-bold">REFERENCE LIBRARY</div>
          <div class="mt-1 text-lg font-semibold">@neurospark/ai-age</div>
          <p class="mt-2 text-sm text-ink/60">Tiny, dependency-free TS/JS module with the canonical <code>scoreInteraction()</code> implementation.</p>
        </a>
      </Reveal>
      <Reveal delay={0.1}>
        <a href="/badge.js" class="block rounded-2xl border border-ink/5 bg-white p-6 hover:border-spark-500/40 transition">
          <div class="text-xs text-deep-500 font-bold">VERIFIER BADGE</div>
          <div class="mt-1 text-lg font-semibold">badge.js</div>
          <p class="mt-2 text-sm text-ink/60">One-line drop-in script that renders a verified-spec-version badge on your product page.</p>
        </a>
      </Reveal>
    </div>

    <Reveal delay={0.15}>
      <div class="mt-16 rounded-3xl bg-gradient-to-br from-spark-500 to-deep-500 p-1">
        <div class="rounded-3xl bg-white p-10">
          <h3 class="text-3xl">Adopt the badge</h3>
          <p class="mt-3 max-w-3xl text-ink/70">Drop one script tag onto your product page. The badge fetches the live spec, verifies the version, and renders inline. No tracking, no cookies — just a hash-pinned signature.</p>
          <pre class="mt-6 rounded-xl bg-ink text-white p-4 text-xs overflow-x-auto"><code>&lt;script async src="https://neurospark.com/badge.js" data-spec="1.0.0"&gt;&lt;/script&gt;
&lt;span data-neurospark-badge&gt;&lt;/span&gt;</code></pre>
          <div class="mt-6 flex items-center gap-3">
            <span class="text-sm text-ink/60">Live preview:</span>
            <span data-neurospark-badge></span>
          </div>
        </div>
      </div>
    </Reveal>

    <Reveal delay={0.2}>
      <div class="mt-16 grid md:grid-cols-2 gap-6">
        <div class="rounded-3xl border border-ink/5 bg-white p-8">
          <h3 class="text-2xl">Why an open standard?</h3>
          <ul class="mt-4 space-y-3 text-ink/70 text-sm">
            <li><b>Trust before lock-in.</b> Adopters can audit the spec, file PRs, and fork it. We commit to never closing it.</li>
            <li><b>Comparability across products.</b> A toy company, a daycare, and a school can all measure the same dimensions.</li>
            <li><b>Research-grade rigour.</b> Every competency carries citations to the peer-reviewed evidence underlying it.</li>
          </ul>
        </div>
        <div class="rounded-3xl border border-ink/5 bg-white p-8">
          <h3 class="text-2xl">Who's adopted it</h3>
          <ul class="mt-4 space-y-3 text-ink/70 text-sm">
            <li>NeuroSpark — first-party reference implementation.</li>
            <li>Coverage-Protocol partners — credited activity counts toward the spec's competencies.</li>
            <li>Looking for early adopters — <a href="mailto:standard@neurospark.com" class="text-spark-500 underline">standard@neurospark.com</a></li>
          </ul>
        </div>
      </div>
    </Reveal>

    <Reveal delay={0.25}>
      <p class="mt-12 text-xs text-ink/40 text-center">
        Versioned at <code>1.0.0</code>. Specification &amp; reference implementation are MIT-licensed.
      </p>
    </Reveal>
  </section>

  <script async src="/badge.js" data-spec="1.0.0"></script>
</Site>
