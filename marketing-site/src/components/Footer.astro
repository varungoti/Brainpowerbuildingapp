---
const year = new Date().getFullYear();
---
<footer class="border-t border-ink/5 bg-white/40 backdrop-blur">
  <div class="container-tight py-12 grid md:grid-cols-4 gap-8 text-sm">
    <div>
      <div class="font-display font-extrabold text-lg">NeuroSpark</div>
      <p class="mt-2 text-ink/70 max-w-xs">Playful brain-building for ages 0–7. Privacy-first. AI-age ready.</p>
    </div>
    <div>
      <div class="font-semibold mb-2">Product</div>
      <ul class="space-y-1 text-ink/70">
        <li><a href="/features">Features</a></li>
        <li><a href="/ai-age">AI-age readiness</a></li>
        <li><a href="/science">Science</a></li>
        <li><a href="/pricing">Pricing</a></li>
      </ul>
    </div>
    <div>
      <div class="font-semibold mb-2">Resources</div>
      <ul class="space-y-1 text-ink/70">
        <li><a href="/blog">Blog</a></li>
        <li><a href="/changelog">Changelog</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </div>
    <div>
      <div class="font-semibold mb-2">Legal</div>
      <ul class="space-y-1 text-ink/70">
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="mailto:hello@neurospark.com">hello@neurospark.com</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-ink/5">
    <div class="container-tight py-4 text-xs text-ink/50 flex justify-between">
      <span>© {year} NeuroSpark Labs</span>
      <span>Built with care in 🇮🇳 + ☁️</span>
    </div>
  </div>
</footer>
