# NeuroSpark Admin App
# Vite + React + TanStack Router/Query + Recharts
# Deploy: Cloudflare Pages or Railway static; protect with Cloudflare Access (zero-trust)

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Edge Function base URL (Supabase Functions or self-hosted Hono)
VITE_EDGE_BASE_URL=https://YOUR_PROJECT.supabase.co/functions/v1

# Analytics warehouse (read-only role recommended)
VITE_NEON_REST_URL=https://api.neon.tech/v2

# Sentry
VITE_SENTRY_DSN=

# Studio orchestrator (Track 5)
VITE_STUDIO_BASE_URL=https://studio.YOUR_DOMAIN.com
VITE_STUDIO_TOKEN=studio-bearer-token

# PostHog (admin analytics consumer)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Postiz frontend URL (used to embed in the Social publishing tab).
# The API key + base URL stay server-side; only set the public frontend URL here.
VITE_POSTIZ_FRONTEND_URL=https://postiz.YOUR_DOMAIN.com
