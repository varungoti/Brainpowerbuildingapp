# Used only for Playwright paywall checkout E2E (`vite build --mode e2e-paywall`).
# Fake host is intercepted by tests — no real Supabase calls.
VITE_SUPABASE_PROJECT_ID=https://e2e-paywall-mock.invalid
VITE_SUPABASE_ANON_KEY=e2e-test-anon-key-not-secret
# Avoid Supabase JS client session calls to an unreachable host during paywall tests
VITE_E2E_SUPPRESS_SB_CLIENT=true
