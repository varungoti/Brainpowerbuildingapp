# NeuroSpark Video Generation Router
# Hono service that exposes one /generate endpoint and routes to the chosen provider
# Quality vs cost vs latency comparison built in.

PORT=4402
VIDEO_SVC_TOKEN=change-me
VIDEO_SVC_MONTHLY_USD_CAP=120
DEFAULT_PROVIDER=runway
LEDGER_PG_URL=postgres://user:pass@neon-host/neondb?sslmode=require

# --- Hosted (closed weights, premium)
RUNWAY_API_KEY=                   # Runway Gen-4 / Gen-4 Turbo
OPENAI_API_KEY=                   # Sora 2 / Sora 2 Pro
GOOGLE_GENAI_API_KEY=             # Veo 3
LUMA_API_KEY=                     # Luma Ray 2
KLING_ACCESS_KEY=                 # Kuaishou Kling 2.1 Master
KLING_SECRET_KEY=
PIKA_API_KEY=                     # Pika 2.2
MINIMAX_API_KEY=                  # MiniMax Hailuo 02
BYTEDANCE_API_KEY=                # Seedance 1.0 Pro
WAN_API_KEY=                      # Alibaba Wan 2.5

# --- Aggregators
REPLICATE_API_TOKEN=
FAL_KEY=

# --- Self-hosted (open weights, run on Runpod / Railway GPU)
HUNYUAN_URL=                      # Tencent HunyuanVideo
HUNYUAN_TOKEN=
LTX_URL=                          # Lightricks LTX-Video 0.9
LTX_TOKEN=
MOCHI_URL=                        # Genmo Mochi 1
MOCHI_TOKEN=
COGVIDEO_URL=                     # Zhipu CogVideoX-5B
COGVIDEO_TOKEN=
OPEN_SORA_URL=                    # Open-Sora 2.0
OPEN_SORA_TOKEN=
SVD_URL=                          # Stable Video Diffusion 1.1
SVD_TOKEN=
ANIMATEDIFF_URL=                  # AnimateDiff Lightning
ANIMATEDIFF_TOKEN=

# --- Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VIDEO_BUCKET=studio-video-clips
