# NeuroSpark Image Service
# Hono router that fans out to every supported image provider for quality + cost A/B
# Deployed on Railway as a single Node service

PORT=4401
IMAGE_SVC_TOKEN=change-me
IMAGE_SVC_MONTHLY_USD_CAP=60
DEFAULT_PROVIDER=ideogram
LEDGER_PG_URL=postgres://user:pass@neon-host/neondb?sslmode=require

# --- Hosted text-in-image
IDEOGRAM_API_KEY=

# --- Hosted photoreal
BFL_API_KEY=                      # FLUX.1.1 [pro], FLUX.1.1 ultra (Black Forest Labs)
RECRAFT_API_KEY=                  # Recraft V3 (vector / illustrative / brand)
LEONARDO_API_KEY=                 # Leonardo Phoenix 1.0
STABILITY_API_KEY=                # Stable Diffusion 3.5 Large
GOOGLE_GENAI_API_KEY=             # Google Imagen 4 Ultra
MIDJOURNEY_API_KEY=               # via 3rd-party proxy
OPENAI_API_KEY=                   # gpt-image-1 (DALL-E 4)

# --- Aggregators / wildcard routers
REPLICATE_API_TOKEN=
FAL_KEY=
TOGETHER_API_KEY=

# --- Self-hosted (brand-character consistency)
SDXL_URL=                         # http://sdxl-runpod:7860
SDXL_TOKEN=
COMFY_URL=                        # ComfyUI workflow runner
COMFY_TOKEN=

# --- Stock fallback (free)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
PIXABAY_API_KEY=

# --- Storage (uploaded results)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
IMAGE_BUCKET=studio-images
