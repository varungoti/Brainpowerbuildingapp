# --- Public URLs (override for prod) ---
FRONTEND_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# --- Crypto secrets ---
JWT_SECRET=replace-with-32-byte-random-string

# --- Storage ---
# local | r2 (Cloudflare R2 — recommended for prod)
STORAGE_PROVIDER=local

# Cloudflare R2 (only if STORAGE_PROVIDER=r2)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKETNAME=neurospark-postiz-uploads
CLOUDFLARE_BUCKET_URL=https://uploads.neurospark.com
CLOUDFLARE_REGION=auto

# --- Provider OAuth credentials (fill the ones you'll use) ---
# X (Twitter) https://developer.x.com
X_API_KEY=
X_API_SECRET=
# LinkedIn https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Facebook + Instagram (Meta Developers app)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# YouTube + GMB (Google Cloud OAuth)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# TikTok https://developers.tiktok.com
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# Reddit https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Pinterest
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
# Bluesky / Mastodon / Threads / Telegram are handled per-account inside Postiz UI
# Dev.to / Medium / Hashnode are handled via per-user API tokens inside Postiz UI

# --- Email notifications (optional) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_ADDRESS=growth@neurospark.com
EMAIL_FROM_NAME=NeuroSpark Postiz

# --- AI features inside Postiz (image/video/text generation) ---
# Already set globally in n8n .env — re-export here so Postiz can also use them.
OPENAI_API_KEY=
