# Self-hosted n8n
N8N_HOST=automation.YOUR_DOMAIN.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://automation.YOUR_DOMAIN.com/
GENERIC_TIMEZONE=Asia/Kolkata

# Encrypts credentials inside n8n
N8N_ENCRYPTION_KEY=change-me-32-bytes-random

# Postgres backing store on Neon (separate DB from analytics)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=neon-host
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SSL_ENABLED=true

# Auth (basic for self-hosted; switch to SSO when scaling)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong

# AI nodes
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Cost cap surfaced to all workflows
N8N_MARKETING_MONTHLY_USD_CAP=200

# Postiz (social distribution layer — see automation/postiz/README.md)
POSTIZ_BASE_URL=http://postiz-api:3000
POSTIZ_FRONTEND_URL=http://localhost:5000
POSTIZ_API_KEY=
USE_POSTIZ=true

# Postiz channel UUIDs (copy from the Postiz UI URL after connecting each)
POSTIZ_CHANNEL_INSTAGRAM=
POSTIZ_CHANNEL_TIKTOK=
POSTIZ_CHANNEL_YOUTUBE=
POSTIZ_CHANNEL_X=
POSTIZ_CHANNEL_LINKEDIN=
POSTIZ_CHANNEL_BLUESKY=
POSTIZ_CHANNEL_THREADS=
POSTIZ_CHANNEL_MASTODON=
POSTIZ_CHANNEL_REDDIT=
POSTIZ_CHANNEL_PINTEREST=
POSTIZ_CHANNEL_MEDIUM=
POSTIZ_CHANNEL_DEVTO=
POSTIZ_CHANNEL_HASHNODE=
POSTIZ_CHANNEL_TELEGRAM=
POSTIZ_CHANNEL_DISCORD=
