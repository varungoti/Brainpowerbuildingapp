# NeuroSpark AI Video Studio
# Remotion 4 + Hono orchestrator + headless Chromium
# Deploy on Railway with a GPU sidecar (Kokoro + optional SDXL)

# --- Core
NODE_ENV=production
PORT=4400
STUDIO_BEARER_TOKEN=change-me-long-random
STUDIO_PUBLIC_URL=https://studio.YOUR_DOMAIN.com

# --- LLM (script + storyboard)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PRIMARY_MODEL=gpt-5
LLM_FALLBACK_MODEL=claude-opus-4-5

# --- Voice (default: self-hosted Kokoro)
KOKORO_URL=http://voice-svc-kokoro:8880/v1
KOKORO_TOKEN=change-me

# Optional voice fallbacks
ELEVENLABS_API_KEY=
PLAYHT_API_KEY=
PLAYHT_USER_ID=
CARTESIA_API_KEY=
HUME_API_KEY=

# --- Image router (calls automation/image-svc)
IMAGE_SVC_URL=http://image-svc:4401
IMAGE_SVC_TOKEN=change-me

# --- Video router (calls automation/video-svc)
VIDEO_SVC_URL=http://video-svc:4402
VIDEO_SVC_TOKEN=change-me

# --- Storage
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
STUDIO_STORAGE_BUCKET=studio

# --- Queue (BullMQ over Redis OR pg-boss over Postgres; we default to pg-boss)
PG_BOSS_URL=postgres://user:pass@neon-host/neondb?sslmode=require

# --- Cost ceiling (USD/month)
STUDIO_MONTHLY_USD_CAP=100

# --- Brand safety
ENABLE_NSFW_GUARD=true
NSFW_THRESHOLD=0.75
